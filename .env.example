# === Anthropic API (Claude) ===
# Required for LLM extraction and detectors
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === GStack API ===
# Required for orchestration and pipeline execution
# Contact GStack team for API access
GSTACK_API_KEY=your_gstack_api_key_here

# === GBrain API ===
# Required for persistent state storage (SelfModel, PartnerModel, RelationshipModel)
# Contact GBrain team for API access
GBRAIN_API_KEY=your_gbrain_api_key_here

# === The Hog API ===
# Required for partner external context enrichment
# Contact The Hog team for API access
THE_HOG_API_KEY=your_the_hog_api_key_here

# === jo API ===
# Required for personal context federation (calendar, photos, notes)
# Contact jo team for API access
JO_API_KEY=your_jo_api_key_here

# === PII Redaction ===
# Set to true to enable PII redaction before data leaves the device
# Recommended: true for production
DYAD_PII_REDACTION=true

# Partner display name — redacted to [PARTNER] in outgoing text before any LLM call
DYAD_PARTNER_NAME=

# Specific conversation (chat_id) to scope ingestion + checkpoints. Optional.
DYAD_CONVERSATION_ID=

# === Engine controls ===
# Log level: trace|debug|info|warn|error
LOG_LEVEL=info

# Hard cap on LLM calls per session (cost guardrail)
MAX_LLM_CALLS_PER_SESSION=500

# Concurrency limit for LLM extraction batch
LLM_CONCURRENCY=4

# === Development Settings ===
# Set to true for debug mode (verbose logging)
DEBUG=false

# Set to true to enable in-app debug panel (Cmd+Shift+D)
DEBUG_PANEL=false
