# === REQUIRED for LLM features ===
# Authenticity scoring and deep conflict analysis require LLM
# Basic rule-based conflict prediction works WITHOUT this
ANTHROPIC_API_KEY=

# GBrain endpoint — used for cognitive context enrichment
GBRAIN_ENDPOINT=http://localhost:3000

# === OPTIONAL ===
OPENAI_API_KEY=
PORT=3003
HEALTH_PORT=8080

# Detection thresholds
VULNERABILITY_ALERT_THRESHOLD=0.7
VULNERABILITY_CRITICAL_THRESHOLD=0.9
AUTHENTICITY_MIN_SCORE=0.6

LOG_LEVEL=info
