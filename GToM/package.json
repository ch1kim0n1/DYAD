{
  "name": "gtom",
  "version": "0.1.0",
  "description": "Cognitive defense and Theory of Mind system",
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "bin": {
    "gtom": "./dist/cli.js",
    "gtom-gbrain-sync": "./dist/commands/gstack-gbrain-sync.js",
    "gstack-gbrain-sync": "./dist/commands/gstack-gbrain-sync.js"
  },
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "require": "./dist/sdk.js",
      "default": "./dist/sdk.js"
    },
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "require": "./dist/sdk.js",
      "default": "./dist/sdk.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "require": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "require": "./dist/cli.js",
      "default": "./dist/cli.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "require": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "migrations/",
    "completions/",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "clean": "node scripts/clean.js",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run verify && npm run check:version-tags",
    "postinstall": "node scripts/postinstall.js",
    "dev": "tsc --watch",
    "serve": "node dist/serve.js",
    "test": "NODE_OPTIONS=\"--localstorage-file=/tmp/jest-ls.json\" jest",
    "test:integration": "NODE_OPTIONS=\"--localstorage-file=/tmp/jest-ls.json\" node scripts/run-jest-env.js INTEGRATION=1",
    "test:watch": "NODE_OPTIONS=\"--localstorage-file=/tmp/jest-ls.json\" jest --watch",
    "test:coverage": "NODE_OPTIONS=\"--localstorage-file=/tmp/jest-ls.json\" jest --coverage",
    "test:property": "jest test/testing-depth.test.ts --runInBand -t property",
    "test:chaos": "jest test/testing-depth.test.ts --runInBand -t chaos",
    "test:fuzz": "jest test/testing-depth.test.ts --runInBand -t fuzz",
    "test:stability": "node scripts/run-jest-env.js STABILITY=1 test/testing-depth.test.ts --runInBand -t stability",
    "test:concurrent": "jest test/testing-depth.test.ts --runInBand -t concurrent",
    "test:contracts": "jest test/testing-depth.test.ts --runInBand -t contract",
    "test:flaky": "node scripts/flaky-test-detect.js",
    "test:mutation": "npx stryker run",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc --options typedoc.json",
    "check:package": "node scripts/quality-gates.js package-contract",
    "check:docs": "node scripts/quality-gates.js docs",
    "check:privacy": "node scripts/quality-gates.js privacy",
    "check:test-isolation": "node scripts/quality-gates.js test-isolation",
    "check:mcp-contract": "node scripts/quality-gates.js mcp-contract",
    "check:all": "node scripts/quality-gates.js all",
    "smoke": "node scripts/quality-gates.js smoke",
    "benchmark": "node scripts/benchmark.js",
    "profile:memory": "node scripts/memory-profile.js",
    "load:k6": "k6 run scripts/load-test-k6.js",
    "load:artillery": "artillery run scripts/artillery.yml",
    "eval:record": "node scripts/eval-tools.js record",
    "eval:list": "node scripts/eval-tools.js list",
    "eval:summary": "node scripts/eval-tools.js summary",
    "eval:compare": "node scripts/eval-tools.js compare",
    "eval:select": "node scripts/eval-tools.js select",
    "verify": "npm run check:all && npm run typecheck && npm test -- --runInBand",
    "ci:local": "node scripts/quality-gates.js ci-local",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "setup": "npm install && npm run build",
    "install:local": "node scripts/install.js",
    "build:binaries": "node scripts/package-binaries.js",
    "check:version-tags": "node scripts/check-version-tags.js"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.33.0 <1",
    "@modelcontextprotocol/sdk": ">=1.0.0 <2",
    "openai": ">=4.0.0 <5"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.11.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "pg": "^8.11.0",
    "proper-lockfile": "^4.1.2",
    "tiktoken": "^1.0.22",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "pure-rand": "^6.1.0",
    "ts-jest": "^29.4.9",
    "typedoc": "^0.25.13",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
