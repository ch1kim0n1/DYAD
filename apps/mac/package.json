{
  "name": "@dyad/mac",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "sidecar:dev": "bun run src-tauri/sidecar/engine-server.ts",
    "sidecar:build": "bun build src-tauri/sidecar/engine-server.ts --compile --outfile src-tauri/binaries/dyad-engine",
    "sidecar:build:darwin-arm64": "bun build src-tauri/sidecar/engine-server.ts --compile --target=bun-darwin-arm64 --outfile src-tauri/binaries/dyad-engine-aarch64-apple-darwin",
    "sidecar:build:darwin-x64": "bun build src-tauri/sidecar/engine-server.ts --compile --target=bun-darwin-x64 --outfile src-tauri/binaries/dyad-engine-x86_64-apple-darwin",
    "sidecar:build:all-darwin": "bun run sidecar:build:darwin-arm64 && bun run sidecar:build:darwin-x64"
  },
  "dependencies": {
    "@dyad/engine": "workspace:*",
    "@dyad/ingestion": "workspace:*",
    "@dyad/shared": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "@tauri-apps/api": "^2.0.0",
    "@visx/axis": "^3.12.0",
    "@visx/curve": "^3.12.0",
    "@visx/grid": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  }
}
