{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "DYAD",
  "version": "0.1.0",
  "identifier": "com.dyad.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        { "name": "binaries/dyad-engine", "sidecar": true, "args": true }
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "DYAD",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/dyad-engine"],
    "icon": ["icons/icon-1024.png", "icons/icon-512.png", "icons/icon-128.png", "icons/icon-32.png"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 600, "height": 400 },
        "appPosition": { "x": 180, "y": 200 },
        "applicationFolderPosition": { "x": 420, "y": 200 }
      }
    }
  }
}
