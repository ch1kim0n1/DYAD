# === REQUIRED — the system will not function without these ===

# Anthropic API key — needed for all task execution
ANTHROPIC_API_KEY=

# Service endpoints
GBRAIN_ENDPOINT=http://localhost:3000
GORCHESTRATOR_ENDPOINT=http://localhost:3002
GMIRROR_ENDPOINT=http://localhost:3003
GTOM_ENDPOINT=http://localhost:3004
GLEARN_ENDPOINT=http://localhost:3005

# === OPTIONAL ===
OPENAI_API_KEY=

# DYAD iMessage daemon settings (macOS only)
DYAD_PII_REDACTION=true
GAGENT_DAEMON_INTERVAL_MS=5000

# Service feature flags — set to true once each service is running
GBRAIN_ENABLED=false
GORCHESTRATOR_ENABLED=false
GMIRROR_ENABLED=false
GTOM_ENABLED=false
GLEARN_ENABLED=false

DEFAULT_PARALLEL=3
MAX_PARALLEL=10
VERIFICATION_THRESHOLD=0.7
LOG_LEVEL=info
