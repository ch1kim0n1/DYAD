# === GBrain — Required ===
PORT=3000
NODE_ENV=production

# Path to the SQLite database file
# For K8s: mount a PVC at /data and set this to /data/gbrain.db
# For local: leave empty to use ~/.gbrain/gbrain.db
GBRAIN_DB_PATH=

# === GBrain — Optional ===
LOG_LEVEL=info

# Authentication token for API endpoints (if set, requires Bearer token for /api routes)
GBRAIN_AUTH_TOKEN=

# Rate limiting for API endpoints (requests per minute per IP)
GBRAIN_RATE_LIMIT_RPM=60
