# === REQUIRED — the system will not function without these ===

# Anthropic API key — needed for pattern mining and proposal generation
ANTHROPIC_API_KEY=

# GBrain endpoint — used for data ingestion and result storage
GBRAIN_ENDPOINT=http://localhost:3000

# === OPTIONAL ===
OPENAI_API_KEY=
PORT=3004
HEALTH_PORT=8080

# Learning configuration
GLEARN_DYAD_MODE=false
RETENTION_DAYS=90
MINING_CADENCE=daily
MIN_DATA_POINTS=100
APPROVAL_THRESHOLD=medium
AUTO_APPLY_BELOW=low
ROLLBACK_ON_REGRESSION=true

# Data source configuration (for bootstrapping pattern mining)
DATA_SOURCE=csv
CSV_IMPORT_PATH=./patterns.csv
JSON_IMPORT_PATH=./patterns.json
DEMO_MODE=false

LOG_LEVEL=info
