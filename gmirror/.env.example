# === REQUIRED — the system will not function without these ===

# Anthropic API key — needed for synthetic user panel and LLM scoring
ANTHROPIC_API_KEY=

# GBrain endpoint — used for result persistence
GBRAIN_ENDPOINT=http://localhost:3000

# === OPTIONAL ===
OPENAI_API_KEY=
PORT=3002
HEALTH_PORT=8080

# Panel configuration
DEFAULT_PANEL_SIZE=10
TRUST_BASELINE=0.7
COGNITIVE_LOAD_BASELINE=0.3

# Rubric thresholds
CORRECTNESS_THRESHOLD=0.8
USER_OUTCOME_THRESHOLD=0.75

LOG_LEVEL=info
