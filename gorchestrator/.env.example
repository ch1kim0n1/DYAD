# === REQUIRED — the system will not function without these ===

# Anthropic API key — needed for ALL task execution (LLM-based intake, sampling, scoring)
ANTHROPIC_API_KEY=

# Service endpoints — all services must be running
GBRAIN_ENDPOINT=http://localhost:3000
GMIRROR_ENDPOINT=http://localhost:3002
GTOM_ENDPOINT=http://localhost:3003

# GStack — external hackathon orchestration service
# Without this, gorchestrator health check marks gstack as unhealthy
# but tasks can still execute if GSTACK_ENABLED=false
GSTACK_ENDPOINT=http://localhost:3001
GSTACK_API_KEY=

# === OPTIONAL ===
OPENAI_API_KEY=

# Sandbox backend: "docker" (default), "inprocess" (no Docker, direct LLM calls), "mock" (for testing), "e2b", "modal"
# Use SANDBOX_BACKEND=inprocess to run without Docker (requires LLM API keys)
# Use MOCK_SANDBOX=1 or SANDBOX_BACKEND=mock to run without Docker or LLM calls (fake results)
SANDBOX_BACKEND=inprocess
MOCK_SANDBOX=0

# Execution limits
MAX_CONCURRENCY=5
DEFAULT_N=3
MAX_COST_USD=10.0
MAX_WALL_TIME_MS=300000
MAX_ATTEMPTS=10
LOG_LEVEL=info
