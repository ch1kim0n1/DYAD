{
  "name": "dyad",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "shared",
    "gbrain",
    "gorchestrator",
    "gmirror",
    "GToM",
    "glearn",
    "gagent"
  ],
  "scripts": {
    "dev:mac": "bun run --cwd apps/mac dev",
    "dev:phone": "bun run --cwd apps/phone start",
    "test": "bun test",
    "test:shared": "bun test packages/shared",
    "test:ingestion": "bun test packages/ingestion",
    "test:engine": "bun test packages/engine",
    "test:dyad": "bun test packages/engine packages/ingestion packages/shared apps/mac",
    "typecheck": "tsc --noEmit",
    "typecheck:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
    "typecheck:engine": "tsc --noEmit -p packages/engine/tsconfig.json",
    "typecheck:mac": "tsc --noEmit -p apps/mac/tsconfig.json",
    "lexicons:build": "node packages/lexicons/scripts/build-nrc-lexicon.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.14",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
