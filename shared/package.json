{
  "name": "@gstack/shared",
  "version": "0.1.0",
  "description": "Shared utilities and core modules for the G-Stack",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js"
    },
    "./cost": {
      "types": "./dist/cost/index.d.ts",
      "import": "./dist/cost/index.js",
      "require": "./dist/cost/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "import": "./dist/health/index.js",
      "require": "./dist/health/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js",
      "require": "./dist/llm/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js",
      "require": "./dist/observability/index.js"
    },
    "./performance": {
      "types": "./dist/performance/index.d.ts",
      "import": "./dist/performance/index.js",
      "require": "./dist/performance/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "import": "./dist/persistence/index.js",
      "require": "./dist/persistence/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js",
      "require": "./dist/security/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist/tools/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js",
      "require": "./dist/workflow/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "core": ["./dist/core/index.d.ts"],
      "config": ["./dist/config/index.d.ts"],
      "cost": ["./dist/cost/index.d.ts"],
      "health": ["./dist/health/index.d.ts"],
      "llm": ["./dist/llm/index.d.ts"],
      "observability": ["./dist/observability/index.d.ts"],
      "performance": ["./dist/performance/index.d.ts"],
      "persistence": ["./dist/persistence/index.d.ts"],
      "security": ["./dist/security/index.d.ts"],
      "tools": ["./dist/tools/index.d.ts"],
      "workflow": ["./dist/workflow/index.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=\"--localstorage-file=/tmp/jest-ls.json\" jest",
    "test:coverage": "NODE_OPTIONS=\"--localstorage-file=/tmp/jest-ls.json\" jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "proper-lockfile": "^4.1.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/retry": "^0.12.5",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
