{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "bun-types"],
    "baseUrl": ".",
    "paths": {
      "@dyad/shared": ["packages/shared/src/index.ts"],
      "@dyad/shared/*": ["packages/shared/src/*"],
      "@dyad/ingestion": ["packages/ingestion/src/index.ts"],
      "@dyad/ingestion/*": ["packages/ingestion/src/*"],
      "@dyad/engine": ["packages/engine/src/index.ts"],
      "@dyad/engine/*": ["packages/engine/src/*"],
      "@dyad/lexicons": ["packages/lexicons/src/index.ts"],
      "@dyad/lexicons/*": ["packages/lexicons/src/*"],
      "@dyad/prompts": ["packages/prompts/src/index.ts"],
      "@dyad/prompts/*": ["packages/prompts/src/*"]
    }
  },
  "include": ["packages/*/src/**/*", "packages/*/tests/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "**/dist", "**/build", "apps", "scripts/fixtures/build-fixtures.mjs", "packages/lexicons/scripts"]
}
